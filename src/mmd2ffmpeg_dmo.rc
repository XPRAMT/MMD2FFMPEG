#include <windows.h>
#include "resource.h"

IDD_ENCODER_SETTINGS DIALOGEX 0, 0, 260, 236
STYLE DS_SETFONT | DS_CONTROL | WS_CHILD | WS_VSCROLL | WS_CLIPCHILDREN | WS_CLIPSIBLINGS
EXSTYLE WS_EX_CONTROLPARENT
FONT 8, "Segoe UI", 400, 0, 0x1
BEGIN
    CONTROL         "", ID_TAB, "SysTabControl32", WS_TABSTOP, 0, 4, 260, 12

    // Video tab
    LTEXT           "Encoder", ID_LABEL_BACKEND, 0, 20, 58, 10
    COMBOBOX        ID_BACKEND, 60, 18, 96, 95, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Codec", ID_LABEL_CODEC, 0, 36, 58, 10
    COMBOBOX        ID_CODEC, 60, 34, 96, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Bit depth", ID_LABEL_DEPTH, 0, 52, 58, 10
    COMBOBOX        ID_DEPTH, 60, 50, 96, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Encoder preset", ID_LABEL_PRESET, 0, 68, 58, 10
    COMBOBOX        ID_PRESET, 60, 66, 96, 95, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Rate control", ID_LABEL_RATE, 0, 84, 58, 10
    COMBOBOX        ID_RATE, 60, 82, 96, 70, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Quality / QP", ID_LABEL_QP, 0, 100, 58, 10
    EDITTEXT        ID_QP, 60, 98, 45, 14, ES_NUMBER | ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "Bitrate (kbps)", ID_LABEL_BITRATE, 112, 100, 62, 10
    EDITTEXT        ID_BITRATE, 176, 98, 42, 14, ES_NUMBER | ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "Complete FFmpeg command (middle section is editable)", ID_COMMAND_HEADING, 0, 117, 260, 10
    LTEXT           "", ID_COMMAND_PREFIX, 0, 129, 260, 24, SS_LEFT
    EDITTEXT        ID_COMMAND, 0, 154, 260, 14, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "", ID_COMMAND_SUFFIX, 0, 170, 260, 18, SS_LEFT
    LTEXT           "Encoder status: not tested", ID_STATUS, 0, 192, 260, 12, SS_LEFTNOWORDWRAP
    LTEXT           "Test must pass before saving or applying.", ID_TEST_REQUIREMENT, 0, 214, 124, 10
    DEFPUSHBUTTON   "Test encoder", ID_REFRESH, 128, 210, 54, 16, WS_TABSTOP
    PUSHBUTTON      "Open log", ID_OPEN_LOG, 186, 210, 58, 16, WS_TABSTOP

    // Audio tab
    LTEXT           "", ID_AUDIO_INTRO, 0, 20, 260, 20
    LTEXT           "Audio format", ID_LABEL_AUDIO_FORMAT, 0, 46, 82, 10
    COMBOBOX        ID_AUDIO_FORMAT, 86, 44, 174, 70, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "", ID_AUDIO_HELP, 0, 62, 260, 20
    LTEXT           "Sample rate / bit depth", ID_LABEL_AUDIO_RATE, 0, 88, 82, 10
    COMBOBOX        ID_AUDIO_RATE, 86, 86, 174, 70, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    // Settings tab
    LTEXT           "Language", ID_LABEL_LANGUAGE, 0, 20, 82, 10
    COMBOBOX        ID_LANGUAGE, 86, 18, 174, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "MMD2FFMPEG", ID_SETTINGS_INFO, 0, 34, 260, 28
    CONTROL         "https://github.com/XPRAMT/MMD2FFMPEG", ID_GITHUB_LINK, "EDIT", ES_LEFT | ES_READONLY | ES_AUTOHSCROLL | WS_TABSTOP, 0, 66, 260, 14
END
